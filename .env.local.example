# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริงจาก Supabase Dashboard > Project Settings > API
# บน Vercel ให้ตั้งค่าตัวแปรทั้ง 3 ตัวนี้ที่ Project Settings > Environment Variables ด้วย

# URL โปรเจกต์ Supabase — ปลอดภัยที่จะ expose ฝั่ง client (ขึ้นต้นด้วย NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# anon/public key — ปลอดภัยที่จะ expose ฝั่ง client (ถูกจำกัดสิทธิ์ด้วย Row Level Security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# service_role key — ห้าม expose ฝั่ง client เด็ดขาด! ใช้เฉพาะฝั่งเซิร์ฟเวอร์ (API routes) เท่านั้น
# key นี้ bypass Row Level Security ทั้งหมด เก็บเป็นความลับเสมอ
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
